<?xml version="1.0"?>
<robot name="mi_robot">

  <material name="gris">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>

  <material name="azul">
    <color rgba="0.2 0.4 0.9 1.0"/>
  </material>

  <material name="rojo">
    <color rgba="0.9 0.2 0.2 1.0"/>
  </material>

  <material name="verde">
    <color rgba="0.2 0.8 0.2 1.0"/>
  </material>

  <link name="world"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="file:///home/aldo/ros2_ws/src/mi_primer_paquete/urdf/Modelos_en_stl/Ensamblaje_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gris"/>
    </visual>

  </link>

  <link name="hombro_link">
    <visual>
      <origin xyz="0 0 0.0517" rpy="1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="file:///home/aldo/ros2_ws/src/mi_primer_paquete/urdf/Modelos_en_stl/Ensamblaje_hombro.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="azul"/>
    </visual>

  </link>

  <link name="brazo_link">
    <visual>
      <origin xyz="0 0 0.0475" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="file:///home/aldo/ros2_ws/src/mi_primer_paquete/urdf/Modelos_en_stl/Ensamblaje_brazo.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="rojo"/>
    </visual>

  </link>

  <link name="antebrazo_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="file:///home/aldo/ros2_ws/src/mi_primer_paquete/urdf/Modelos_en_stl/Ensamblaje_antebrazo.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="verde"/>
    </visual>

  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint_base_hombro" type="revolute">
    <parent link="base_link"/>
    <child link="hombro_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>

    <limit lower="-3.14" upper="3.14" effort="10" velocity="1.0"/>
  </joint>

  <joint name="joint_hombro_brazo" type="revolute">
    <parent link="hombro_link"/>
    <child link="brazo_link"/>
    <origin xyz="0 0 0.1117" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.85" upper="1.9" effort="10" velocity="1.0"/>
  </joint>

  <joint name="joint_brazo_antebrazo" type="revolute">
    <parent link="brazo_link"/>
    <child link="antebrazo_link"/>
    <origin xyz="0 0 0.120" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.87" effort="10" velocity="1.0"/>
  </joint>

</robot>